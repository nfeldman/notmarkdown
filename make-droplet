#!/usr/bin/env bash
#
# make-droplet — build a macOS drag-and-drop app around mdexport, from source.
#
# Compiles droplet.applescript into an .app with osacompile (built into macOS),
# so the app is version-controlled and rebuildable rather than a hand-assembled
# Automator blob. Drop Markdown files or folders on the result to publish them;
# each output is written as a sibling of what you dropped.
#
# Usage:
#   ./make-droplet                 # -> ~/Desktop/notmarkdown.app
#   ./make-droplet /path/to/My.app # -> a chosen location
# ---------------------------------------------------------------------------
set -euo pipefail

SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do SELF="$(readlink "$SELF")"; done
ASSETS="$(cd "$(dirname "$SELF")" && pwd)"
SRC="$ASSETS/droplet.applescript"

OUT="${1:-$HOME/Desktop/notmarkdown.app}"

command -v osacompile >/dev/null 2>&1 || { echo "make-droplet: osacompile not found (macOS only)" >&2; exit 1; }
[[ -f "$SRC" ]] || { echo "make-droplet: missing $SRC" >&2; exit 1; }
command -v mdexport >/dev/null 2>&1 || echo "make-droplet: note — 'mdexport' isn't on PATH yet; the app expects it in ~/.local/bin (see the README Install step)." >&2

mkdir -p "$(dirname "$OUT")"
rm -rf "$OUT"
osacompile -o "$OUT" "$SRC"

# osacompile emits a Carbon-era document-type declaration (CFBundleTypeExtensions
# "*"), which recent macOS does not reliably use to accept drops — folders in
# particular. Declare a modern UTI so Finder routes ANY dropped file or folder to
# the on-open handler. public.item is the root type both files and folders share.
PLIST="$OUT/Contents/Info.plist"
if [[ -f "$PLIST" ]] && command -v /usr/libexec/PlistBuddy >/dev/null 2>&1; then
  /usr/libexec/PlistBuddy -c "Add :CFBundleDocumentTypes:0:LSItemContentTypes array" "$PLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Add :CFBundleDocumentTypes:0:LSItemContentTypes:0 string public.item" "$PLIST" 2>/dev/null || true
fi
# Refresh Launch Services so the change takes effect without a logout.
LSREG="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
[[ -x "$LSREG" ]] && "$LSREG" -f "$OUT" 2>/dev/null || true

echo "built $OUT"
echo "Drag Markdown files or folders onto the app icon to publish. (First run: right-click → Open to clear Gatekeeper.)"
