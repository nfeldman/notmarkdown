#!/usr/bin/env bash
#
# mdexport — turn a Markdown file (with embedded Mermaid + LaTeX) into a durable,
# self-contained document where NOTHING is left as raw syntax.
#
#   HTML : one self-contained .html file — inline-SVG diagrams, MathML equations
#          (no JavaScript, no network, ~20 KB), high-quality typography. The
#          legible/editable durable copy: open it in any browser for decades.
#   PDF  : via Typst — fast, archival-grade typesetting, diagrams + math baked in.
#          `--pdfa` emits an ISO-standard PDF/A archival file.
#
# Markdown stays your source of truth; every export is a reproducible snapshot.
#
# Usage:
#   mdexport FILE.md                 # -> FILE.html (default)
#   mdexport FILE.md --pdf           # -> FILE.pdf
#   mdexport FILE.md --all           # -> FILE.html and FILE.pdf
#   mdexport FILE.md --pdfa          # -> FILE.pdf as PDF/A-2b (archival)
#   mdexport FILE.md --pdf-from-html # -> FILE.pdf by printing the HTML (needs a browser)
#   mdexport FILE.md --epub          # -> FILE.epub (portable ebook, assets embedded)
#   mdexport FILE.md --out DIR       # write outputs to DIR (created) instead of alongside
#   mdexport FILE.md --html --open   # build HTML and open it
#   mdexport FILE.md --strict        # abort the build if ANY diagram fails
#   mdexport FILE.md --follow        # also build every same-dir .md it links to (HTML)
#   mdexport FILE.md --bundle        # --follow, then zip the set into FILE.zip
#   mdexport FILE.md --watch         # rebuild (default format) on every save
#
# By default a diagram that fails to render is isolated to a visible placeholder
# and the rest of the document still builds; --strict restores all-or-nothing.
#
# Requires: pandoc, mermaidx (pip), and — for PDF — typst. All from setup.sh.
# ---------------------------------------------------------------------------
set -euo pipefail

# Assets live next to this script (resolve symlinks so it works from ~/.local/bin).
SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do SELF="$(readlink "$SELF")"; done
ASSETS="$(cd "$(dirname "$SELF")" && pwd)"
LUA="$ASSETS/mermaid.lua"
MDLINKS="$ASSETS/mdlinks.lua"   # --follow link rewrite/discovery (no-op otherwise)
HEADER="$ASSETS/typography.html"
# svg-scope id-namespaces inline HTML SVGs so multiple diagrams don't collide.
export MDEXPORT_SVGSCOPE="${MDEXPORT_SVGSCOPE:-$ASSETS/svg-scope}"

# ~/.local/bin holds mermaidx (pip --user); make sure it resolves.
export PATH="$HOME/.local/bin:$PATH"

# Mermaid renderer the filter shells out to. Default: the browser-free mermaidx
# wrapper (no headless Chrome — the durable choice; SVG-only, ~5 diagram types,
# other types fall back to a visible placeholder). Opt in to full fidelity across
# every diagram type with the official mermaid-cli: MDEXPORT_MERMAID=mmdc (fetches
# ~170 MB chrome-headless-shell once); the filter then feeds it per-format
# artifacts (inline SVG for HTML, hi-DPI PNG for PDF) and batches the whole doc.
export MDEXPORT_MERMAID="${MDEXPORT_MERMAID:-$ASSETS/mermaid-render}"
# Renderer KIND drives per-format behavior (mmdc: PNG-for-PDF + whole-doc batch).
# Guessed from the renderer name; set MDEXPORT_MERMAID_KIND=mmdc|svg to force it.
if [[ -z "${MDEXPORT_MERMAID_KIND:-}" ]]; then
  case "${MDEXPORT_MERMAID##*/}" in
    mmdc*) MDEXPORT_MERMAID_KIND=mmdc ;;
    *)     MDEXPORT_MERMAID_KIND=svg  ;;
  esac
fi
export MDEXPORT_MERMAID_KIND

die() { printf '\033[1;31mmdexport:\033[0m %s\n' "$1" >&2; exit 1; }
info() { printf '\033[1;34m==>\033[0m %s\n' "$1" >&2; }
ok()   { printf '\033[1;32m ok\033[0m %s\n' "$1" >&2; }

# --- parse args ------------------------------------------------------------
IN=""; DO_HTML=0; DO_PDF=0; PDFA=0; OPEN=0; WATCH=0; STRICT=0; FOLLOW=0; PDF_HTML=0; DO_EPUB=0; BUNDLE=0
OUT_DIR=""; EXPECT_OUT=0
BUILD_ARGS=()   # args minus --watch, for the watcher to re-invoke a single build
for a in "$@"; do
  if [[ $EXPECT_OUT -eq 1 ]]; then OUT_DIR="$a"; EXPECT_OUT=0; BUILD_ARGS+=("$a"); continue; fi
  case "$a" in
    --html) DO_HTML=1; BUILD_ARGS+=("$a") ;;
    --pdf)  DO_PDF=1;  BUILD_ARGS+=("$a") ;;
    --pdfa) DO_PDF=1; PDFA=1; BUILD_ARGS+=("$a") ;;
    --pdf-from-html) PDF_HTML=1; BUILD_ARGS+=("$a") ;;
    --epub) DO_EPUB=1; BUILD_ARGS+=("$a") ;;
    --all)  DO_HTML=1; DO_PDF=1; BUILD_ARGS+=("$a") ;;
    --out)   EXPECT_OUT=1; BUILD_ARGS+=("$a") ;;          # write outputs to DIR (next arg)
    --out=*) OUT_DIR="${a#--out=}"; BUILD_ARGS+=("$a") ;;
    --open) OPEN=1; BUILD_ARGS+=("$a") ;;
    --strict) STRICT=1; BUILD_ARGS+=("$a") ;;
    --follow) FOLLOW=1; BUILD_ARGS+=("$a") ;;
    --bundle) BUNDLE=1; FOLLOW=1; BUILD_ARGS+=("$a") ;;   # bundle = follow, then zip the set
    --watch) WATCH=1 ;;
    -*) die "unknown option: $a" ;;
    *) IN="$a"; BUILD_ARGS+=("$a") ;;
  esac
done
[[ $EXPECT_OUT -eq 1 ]] && die "--out needs a directory argument"
# --strict: one failed diagram aborts the whole build (archival/CI all-or-nothing).
# Default: mermaid.lua isolates a failed diagram to a visible placeholder and the
# rest of the document still renders. The filter reads this via the environment.
[[ $STRICT -eq 1 ]] && export MDEXPORT_STRICT=1
[[ -n "$IN" ]] || die "no input. Try: mdexport FILE.md|DIR [--pdf|--all|--pdfa|--pdf-from-html|--epub|--out DIR|--strict|--follow|--bundle|--watch]"
[[ -f "$IN" || -d "$IN" ]] || die "not found: $IN"
# Default output is HTML unless another output was explicitly asked for.
[[ $DO_HTML -eq 0 && $DO_PDF -eq 0 && $PDF_HTML -eq 0 && $DO_EPUB -eq 0 ]] && DO_HTML=1
# --follow (and --bundle) export a whole set of interlinked same-directory docs;
# only HTML makes sense there (cross-doc navigation), so they force HTML-only.
if [[ $FOLLOW -eq 1 ]]; then
  { [[ $DO_PDF -eq 1 ]] || [[ $PDF_HTML -eq 1 ]] || [[ $DO_EPUB -eq 1 ]]; } && info "--follow/--bundle build HTML only; ignoring the PDF/EPUB request"
  DO_HTML=1; DO_PDF=0; PDFA=0; PDF_HTML=0; DO_EPUB=0
fi
# --pdf-from-html renders the built HTML to PDF with a browser (high typographic
# fidelity: the PDF matches the HTML). It needs the HTML and supersedes the Typst
# PDF path (--pdf/--pdfa) rather than producing two different FILE.pdf.
if [[ $PDF_HTML -eq 1 ]]; then DO_HTML=1; DO_PDF=0; PDFA=0; fi

command -v pandoc >/dev/null 2>&1 || die "pandoc not found (brew install pandoc)"
# Check whichever renderer is selected (first token, in case it carries args).
RENDERER_BIN="${MDEXPORT_MERMAID%% *}"
command -v "$RENDERER_BIN" >/dev/null 2>&1 || die "mermaid renderer '$RENDERER_BIN' not found \
(default is the mermaidx wrapper — 'uv tool install mermaidx'; or set MDEXPORT_MERMAID=mmdc for full fidelity)"
if [[ $DO_PDF -eq 1 ]]; then
  command -v typst >/dev/null 2>&1 || die "typst not found (brew install typst)"
fi

base="$(basename "${IN%.*}")"
dir="$(dirname "$IN")"

# --out DIR writes every output to DIR instead of next to the source. Create it
# once, up front. outdir SRCDIR returns the effective output dir: OUT_DIR if set,
# else the given source dir (so callers pass the dir the output would default to).
if [[ -n "$OUT_DIR" ]]; then mkdir -p "$OUT_DIR" || die "cannot create --out directory: $OUT_DIR"; fi
outdir() { if [[ -n "$OUT_DIR" ]]; then printf '%s' "$OUT_DIR"; else printf '%s' "$1"; fi; }

# --- no-syntax-leak guarantee -----------------------------------------------
# Diagrams are guaranteed for BOTH formats at the source: mermaid.lua aborts the
# whole pandoc run (non-zero exit) ONLY under --strict; by default a failed
# diagram becomes a visible placeholder so the rest of the document survives.
# Either way a raw ```mermaid fence can never reach the HTML or PDF: the HTML
# check below is a belt-and-braces sentinel, and a placeholder is deliberate
# visible content, not raw syntax. (Math that pandoc itself cannot parse is
# passed through with a pandoc warning on stderr — watch the build output;
# that's a source-LaTeX error, not a pipeline failure.)
check_html_leak() {
  local f="$1"
  grep -q 'class="mermaid"' "$f" && die "leak: an unrendered mermaid block is still in $f"
  # Surface isolated failures so a placeholder isn't mistaken for a clean build.
  # Count only the wrapper <div> (its inner <pre> shares the class) for an exact tally.
  # `|| true`: grep exits 1 when it finds nothing, which under `set -o pipefail`
  # would fail the assignment and (via `set -e`) abort an otherwise-clean build.
  local n; n="$(grep -o '<div class="notmarkdown-render-error"' "$f" 2>/dev/null | wc -l | tr -d ' ' || true)"
  if [[ "$n" -gt 0 ]]; then
    printf '\033[1;33m !!\033[0m %s — %s diagram(s) failed and were replaced by a placeholder (use --strict to fail the build instead)\n' "$(basename "$f")" "$n" >&2
  fi
  ok "$(basename "$f") — self-contained, no raw mermaid ($(wc -c <"$f" | tr -d ' ') bytes)"
}

build_html() {
  local out="$(outdir "$dir")/$base.html"
  info "HTML  $IN -> $out"
  MDEXPORT_TMP="$TMP" pandoc "$IN" \
    --from=markdown+tex_math_dollars+tex_math_single_backslash+gfm_auto_identifiers \
    --to=html5 \
    --standalone \
    --embed-resources \
    --lua-filter="$LUA" \
    --lua-filter="$MDLINKS" \
    --mathml \
    --include-in-header="$HEADER" \
    --output="$out"
  check_html_leak "$out"
  [[ $OPEN -eq 1 ]] && open "$out"
  return 0
}

build_pdf() {
  local out="$(outdir "$dir")/$base.pdf"
  if [[ $PDFA -eq 1 ]]; then
    # Route through a .typ intermediate so we can request a PDF/A standard.
    info "PDF/A $IN -> $out"
    local typ="$TMP/$base.typ"
    MDEXPORT_TMP="$TMP" pandoc "$IN" \
      --from=markdown+tex_math_dollars+tex_math_single_backslash+gfm_auto_identifiers \
      --to=typst \
      --lua-filter="$LUA" \
      --output="$typ"
    # --root / so the absolute SVG paths in the .typ resolve from the filesystem
    # root (otherwise Typst treats a leading "/" as relative to its own root).
    typst compile --root / --pdf-standard a-2b "$typ" "$out"
  else
    info "PDF   $IN -> $out"
    MDEXPORT_TMP="$TMP" pandoc "$IN" \
      --from=markdown+tex_math_dollars+tex_math_single_backslash+gfm_auto_identifiers \
      --lua-filter="$LUA" \
      --pdf-engine=typst \
      --output="$out"
  fi
  ok "$(basename "$out") ($(wc -c <"$out" | tr -d ' ') bytes)"
  [[ $OPEN -eq 1 ]] && open "$out"
  return 0
}

# Locate a Chromium-family browser for --pdf-from-html. Preference: an explicit
# MDEXPORT_CHROME, then a browser on PATH, then the common macOS app bundles, then
# the chrome-headless-shell that mermaid-cli (mmdc) installs. Prints the path.
find_chrome() {
  if [[ -n "${MDEXPORT_CHROME:-}" && -x "${MDEXPORT_CHROME}" ]]; then printf '%s\n' "$MDEXPORT_CHROME"; return 0; fi
  local c
  for c in google-chrome google-chrome-stable chromium chromium-browser brave microsoft-edge; do
    command -v "$c" >/dev/null 2>&1 && { command -v "$c"; return 0; }
  done
  for c in \
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    "/Applications/Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge" \
    "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"; do
    [[ -x "$c" ]] && { printf '%s\n' "$c"; return 0; }
  done
  # newest chrome-headless-shell from the puppeteer cache (mmdc's engine)
  c="$(ls -t "$HOME"/.cache/puppeteer/chrome-headless-shell/*/*/chrome-headless-shell 2>/dev/null | head -1 || true)"
  [[ -n "$c" && -x "$c" ]] && { printf '%s\n' "$c"; return 0; }
  return 1
}

# High-fidelity PDF: print the already-built self-contained HTML with a browser,
# so the PDF inherits typography.html exactly (code styling, measure, fonts, …).
build_pdf_html() {
  local od; od="$(outdir "$dir")"
  local html="$od/$base.html" out="$od/$base.pdf" chrome err
  [[ -f "$html" ]] || die "internal: HTML for $IN was not built"
  chrome="$(find_chrome)" || die "--pdf-from-html needs a Chromium browser. Install Google \
Chrome, or 'npm i -g @mermaid-js/mermaid-cli' (brings chrome-headless-shell), or point \
MDEXPORT_CHROME at a browser binary."
  info "PDF   $html -> $out (via $(basename "$chrome"))"
  # Absolute file:// URL (spaces percent-encoded so the browser accepts it).
  local abs; abs="$(cd "$od" && pwd)/$base.html"
  err="$TMP/chrome.err"
  if ! "$chrome" --headless --no-sandbox --no-pdf-header-footer \
        --print-to-pdf="$out" "file://${abs// /%20}" >/dev/null 2>"$err"; then
    die "browser print-to-pdf failed: $(tail -1 "$err" 2>/dev/null)"
  fi
  [[ -s "$out" ]] || die "browser produced no PDF: $(tail -1 "$err" 2>/dev/null)"
  ok "$(basename "$out") ($(wc -c <"$out" | tr -d ' ') bytes)"
  [[ $OPEN -eq 1 ]] && open "$out"
  return 0
}

# EPUB: a portable ZIP of interlinked XHTML + packaged assets (diagrams embedded
# as images, math as MathML) built straight from the Markdown by pandoc. Reflowable
# — deliberately NOT styled with typography.html, since e-readers own their layout.
build_epub() {
  local out="$(outdir "$dir")/$base.epub"
  info "EPUB  $IN -> $out"
  # pandoc derives the epub's dc:language from the shell locale when the document
  # sets none; a "C"/POSIX/unset locale (common in CI and containers) yields an
  # invalid BCP 47 tag ("C") that epubcheck rejects (OPF-092). Substitute a valid
  # fallback for that case only — a valid locale is kept, and an explicit `lang:`
  # in the document always wins over the locale regardless.
  local loc="${LC_ALL:-${LANG:-}}"
  case "$loc" in ''|C|C.*|POSIX|POSIX.*) loc=en_US.UTF-8 ;; esac
  LC_ALL="$loc" LANG="$loc" MDEXPORT_TMP="$TMP" pandoc "$IN" \
    --from=markdown+tex_math_dollars+tex_math_single_backslash+gfm_auto_identifiers \
    --to=epub3 \
    --lua-filter="$LUA" \
    --mathml \
    --metadata title="$base" \
    --output="$out"
  ok "$(basename "$out") ($(wc -c <"$out" | tr -d ' ') bytes)"
  [[ $OPEN -eq 1 ]] && open "$out"
  return 0
}

run_once() {
  TMP="$(mktemp -d)"
  # RETURN cleans up after a normal build (incl. each --watch iteration); EXIT
  # covers the die()/errexit path, where RETURN traps don't fire.
  trap '[[ -n "${TMP:-}" ]] && rm -rf "$TMP"' RETURN EXIT
  [[ $DO_HTML   -eq 1 ]] && build_html
  if   [[ $PDF_HTML -eq 1 ]]; then build_pdf_html   # browser-rendered PDF from the HTML
  elif [[ $DO_PDF   -eq 1 ]]; then build_pdf; fi     # Typst-rendered PDF from Markdown
  [[ $DO_EPUB   -eq 1 ]] && build_epub
  return 0   # never let a false [[ ]] above become this function's (and the script's) exit status
}

# --- --follow: export a whole set of interlinked same-directory docs ---------
# Breadth-first build of the input plus every same-directory doc reachable through
# its markdown links (transitively). HTML only. Link discovery AND rewriting are
# done in mdlinks.lua on the parsed AST (so ./ prefixes, reference-style links,
# titles, #fragments and %-encoded names all work, code blocks are never followed,
# and encoded path separators can't escape the directory); build_html writes each
# doc's same-dir .md references, one per line, to $MDEXPORT_FOLLOW_OUT.
follow_build() {
  TMP="$(mktemp -d)"
  trap '[[ -n "${TMP:-}" ]] && rm -rf "$TMP"' RETURN EXIT
  local want_open=$OPEN; OPEN=0          # open only the entry file, at the very end
  local links="$TMP/follow-refs"
  export MDEXPORT_FOLLOW_OUT="$links"
  # Capture the entry's identity up front — the loop reassigns IN/dir/base per doc.
  local entry_dir; entry_dir="$(cd "$(dirname "$IN")" && pwd)"
  local entry_base; entry_base="$(basename "${IN%.*}")"
  local -a queue=("$IN") built=()
  local seen=" " f abs ref
  while [[ ${#queue[@]} -gt 0 ]]; do
    f="${queue[0]}"; queue=("${queue[@]:1}")
    abs="$(cd "$(dirname "$f")" 2>/dev/null && pwd)/$(basename "$f")"
    case "$seen" in *" $abs "*) continue ;; esac      # already built — skip cycles
    seen+="$abs "
    [[ -f "$f" ]] || { info "skip (missing): $f"; continue; }
    IN="$f"; dir="$(dirname "$f")"; base="$(basename "${f%.*}")"
    : > "$links"                                       # mdlinks.lua appends refs here
    build_html
    built+=("$(outdir "$dir")/$base.html")
    while read -r ref; do
      # Belt-and-braces: the filter already rejects separators, but never enqueue a
      # ref that isn't a plain same-directory filename that actually exists.
      case "$ref" in ''|*/*|.|..) continue ;; esac
      [[ -f "$dir/$ref" ]] && queue+=("$dir/$ref")
    done < "$links"
  done
  info "followed ${#built[@]} file(s)"
  # --bundle: zip EXACTLY the built set (by basename, flat) into <entry>.zip — the
  # bundle scope is the follow scope, not "every .html in the directory". The docs
  # were written to the effective output dir (--out or the entry's dir); zip from there.
  local odir; odir="$(outdir "$entry_dir")"
  if [[ $BUNDLE -eq 1 && ${#built[@]} -gt 0 ]]; then
    local zip="$odir/$entry_base.zip" names=() h
    for h in "${built[@]}"; do names+=("$(basename "$h")"); done
    rm -f "$zip"
    ( cd "$odir" && python3 -m zipfile -c "$zip" "${names[@]}" ) \
      || die "failed to create bundle: $zip"
    ok "$(basename "$zip") ($(wc -c <"$zip" | tr -d ' ') bytes, ${#names[@]} docs)"
  fi
  [[ $want_open -eq 1 && ${#built[@]} -gt 0 ]] && open "${built[0]}"
  return 0
}

# --- directory input: process every top-level *.md, output as a SIBLING --------
# The output is always a sibling of the input directory: HTML/PDF go into a sibling
# DIRECTORY (one file per .md, HTML cross-links rewritten); EPUB becomes one combined
# ebook FILE beside the input dir; --bundle a single .zip beside it. --out overrides
# where the sibling lands.
dir_build() {
  TMP="$(mktemp -d)"
  trap '[[ -n "${TMP:-}" ]] && rm -rf "$TMP"' RETURN EXIT
  local d dbase dparent user_out
  d="${IN%/}"; dbase="$(basename "$d")"; dparent="$(dirname "$d")"; user_out="$OUT_DIR"
  local -a mds=(); local f
  for f in "$d"/*.md; do [[ -f "$f" ]] && mds+=("$f"); done
  [[ ${#mds[@]} -gt 0 ]] || die "no .md files in directory: $d"

  # EPUB: one combined ebook, a sibling FILE of the input directory.
  if [[ $DO_EPUB -eq 1 ]]; then
    [[ -n "$user_out" ]] && mkdir -p "$user_out"
    local out="${user_out:-$dparent}/$dbase.epub"
    info "EPUB  $d/ -> $out (${#mds[@]} docs)"
    local loc="${LC_ALL:-${LANG:-}}"; case "$loc" in ''|C|C.*|POSIX|POSIX.*) loc=en_US.UTF-8 ;; esac
    LC_ALL="$loc" LANG="$loc" MDEXPORT_TMP="$TMP" pandoc "${mds[@]}" \
      --from=markdown+tex_math_dollars+tex_math_single_backslash+gfm_auto_identifiers \
      --to=epub3 --lua-filter="$LUA" --mathml --metadata title="$dbase" --output="$out"
    ok "$(basename "$out") ($(wc -c <"$out" | tr -d ' ') bytes)"
    [[ $OPEN -eq 1 ]] && open "$out"
    return 0
  fi

  # HTML/PDF: a sibling DIRECTORY of per-file outputs.
  local fmt=html; { [[ $DO_PDF -eq 1 ]] || [[ $PDF_HTML -eq 1 ]]; } && fmt=pdf
  local sib="${user_out:-$dparent/$dbase-$fmt}"
  mkdir -p "$sib"
  OUT_DIR="$sib"                                  # route per-file builds into the sibling dir
  export MDEXPORT_FOLLOW_OUT="$TMP/dirlinks"      # activate .md->.html rewriting in build_html
  local want_open=$OPEN; OPEN=0
  local -a built=()
  for f in "${mds[@]}"; do
    IN="$f"; dir="$(dirname "$f")"; base="$(basename "${f%.*}")"
    : > "$MDEXPORT_FOLLOW_OUT"
    [[ $DO_HTML -eq 1 ]] && { build_html; built+=("$sib/$base.html"); }
    if   [[ $PDF_HTML -eq 1 ]]; then build_pdf_html
    elif [[ $DO_PDF   -eq 1 ]]; then build_pdf; fi
  done
  info "wrote ${#mds[@]} document(s) to $sib/"
  # --bundle: zip the built HTML set into a single .zip, a sibling FILE.
  if [[ $BUNDLE -eq 1 && ${#built[@]} -gt 0 ]]; then
    local zip="${user_out:-$dparent}/$dbase.zip" names=() h
    for h in "${built[@]}"; do names+=("$(basename "$h")"); done
    rm -f "$zip"
    ( cd "$sib" && python3 -m zipfile -c "$zip" "${names[@]}" ) || die "failed to create bundle: $zip"
    ok "$(basename "$zip") ($(wc -c <"$zip" | tr -d ' ') bytes, ${#names[@]} docs)"
  fi
  [[ $want_open -eq 1 ]] && open "$sib"
  return 0
}

if [[ -d "$IN" ]]; then
  dir_build
elif [[ $FOLLOW -eq 1 ]]; then
  follow_build
elif [[ $WATCH -eq 1 ]]; then
  info "watching $IN (Ctrl-C to stop)"
  if command -v watchexec >/dev/null 2>&1; then
    exec watchexec --watch "$IN" -- "$0" "${BUILD_ARGS[@]}"
  fi
  # Fallback watcher (no watchexec): poll mtime once a second.
  last=""
  while true; do
    now="$(stat -f %m "$IN" 2>/dev/null || echo 0)"
    if [[ "$now" != "$last" ]]; then last="$now"; run_once || true; fi
    sleep 1
  done
else
  run_once
fi
