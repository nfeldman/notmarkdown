# mdexport writes its output next to the source .md — don't commit generated docs.
*.html
*.pdf
*.epub
*.zip

# ...but the GitHub Pages site is a real source file, not generated output.
!docs/index.html

# Python bytecode from the test suite.
__pycache__/
*.pyc

# Machine-local Claude Code settings (never publish these).
.claude/settings.local.json
